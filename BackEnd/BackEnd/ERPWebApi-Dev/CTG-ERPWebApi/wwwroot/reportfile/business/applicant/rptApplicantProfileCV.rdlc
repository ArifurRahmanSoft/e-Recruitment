                              </Style>
                            </TextRun>
                            <TextRun>
                              <Value>=IIF(Fields!blood_group.Value = 1, "A+", 
   IIF(Fields!blood_group.Value = 2, "A-", 
   IIF(Fields!blood_group.Value = 3, "AB+", 
   IIF(Fields!blood_group.Value = 4, "AB-", 
   IIF(Fields!blood_group.Value = 5, "B+", 
   IIF(Fields!blood_group.Value = 6, "B-", 
   IIF(Fields!blood_group.Value = 7, "O+", 
   IIF(Fields!blood_group.Value = 8, "O-", 
   IIF(Fields!blood_group.Value = 9, "Unknown", "Unknown")))))))))</Value>
