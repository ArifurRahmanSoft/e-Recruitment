                      <CellContents>
                        <Textbox Name="Textbox194">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Work Experience  </Value>
                                  <Style />
                                </TextRun>
                                <TextRun>
                                  <Value>=Int(First(Fields!grandTotalDays.Value, "DataSet1")/365) 
 &amp; IIf((First(Fields!grandTotalDays.Value, "DataSet1") Mod 365) &gt; 0, "+", "")</Value>
                                  <Style />
                                </TextRun>
                                <TextRun>
                                  <Value> Years </Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Center</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox194</rd:DefaultName>
                          <Style>
